<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>TiDB on 随记</title><link>/tags/tidb/</link><description>Recent content in TiDB on 随记</description><generator>Hugo</generator><language>zh-cn</language><lastBuildDate>Tue, 24 Sep 2019 20:00:00 +0800</lastBuildDate><atom:link href="/tags/tidb/index.xml" rel="self" type="application/rss+xml"/><item><title>TiDB 笔记</title><link>/posts/learn-tidb/</link><pubDate>Tue, 24 Sep 2019 20:00:00 +0800</pubDate><guid>/posts/learn-tidb/</guid><description>&lt;h2 id="启动单节点的-tidb">启动单节点的 TiDB&lt;/h2>
&lt;p>完整的 PD + TiKV + TiDB:&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" style="background-color:#f0f0f0;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-bash" data-lang="bash">&lt;span style="display:flex;">&lt;span>docker run -dt --restart&lt;span style="color:#666">=&lt;/span>always --name tipd -p 2379:2379 -p 4000:4000 -p 10080:10080 pingcap/pd:v2.1.15 --data-dir&lt;span style="color:#666">=&lt;/span>/data/tipd
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>docker run -dt --restart&lt;span style="color:#666">=&lt;/span>always --name tikv --net&lt;span style="color:#666">=&lt;/span>container:tipd pingcap/tikv:v2.1.15 --data-dir&lt;span style="color:#666">=&lt;/span>/data/tikv --pd-endpoints&lt;span style="color:#666">=&lt;/span>127.0.0.1:2379
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>docker run -dt --restart&lt;span style="color:#666">=&lt;/span>always --name tidb --net&lt;span style="color:#666">=&lt;/span>container:tipd pingcap/tidb:v2.1.15 --store&lt;span style="color:#666">=&lt;/span>tikv --path&lt;span style="color:#666">=&lt;/span>127.0.0.1:2379
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>只有 TiDB：&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" style="background-color:#f0f0f0;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-bash" data-lang="bash">&lt;span style="display:flex;">&lt;span>&lt;span style="color:#60a0b0;font-style:italic"># 默认 path 为 /tmp/tidb&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>docker run -dt --restart&lt;span style="color:#666">=&lt;/span>always --name tidb -p 4000:4000 -p 10080:10080 pingcap/tidb:v2.1.15 --path&lt;span style="color:#666">=&lt;/span>/data/tidb
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div></description></item></channel></rss>